# ================================
# Time Work - Consolidated .env
# ================================
# Copy this file to .env and fill in your values

# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/timework"

# Stack Auth Configuration
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_publishable_key
STACK_SECRET_SERVER_KEY=your_secret_key

# Application Settings
SUPER_ADMIN_EMAIL="admin@example.com"

# --- AI Integrations ---
GOOGLE_GENERATIVE_AI_API_KEY="your_google_ai_studio_api_key_here"
OPENROUTER_API_KEY="your_openrouter_api_key_here"
GROQ_API_KEY="your_groq_api_key_here"

# Cloudflare R2 Storage (Optional)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="timework-uploads"
# Optional: Public Access URL (if using custom domain or worker)
R2_PUBLIC_URL="https://cdn.example.com"
