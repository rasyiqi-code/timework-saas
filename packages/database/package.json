{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- npx tsx src/seed.ts",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "build": "dotenv -e ../../.env -- prisma generate"
  },
  "devDependencies": {
    "@prisma/config": "^7.3.0",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}